# Password for the /admin review queue. Set a real one before deploying.
ADMIN_PASSWORD=changeme

# Supabase Postgres — use the pooled connection string from:
# Project Settings > Database > Connection string > Transaction pooler.
# Keep this server-only; never prefix it with NEXT_PUBLIC_.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# AWS S3 — where uploaded trip photos are stored.
# Region and bucket have working defaults; credentials must be set.
AWS_REGION=us-east-2
S3_BUCKET=tripscale-photo-blog
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
