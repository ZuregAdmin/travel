# Password for the /admin review queue. Set a real one before deploying.
ADMIN_PASSWORD=changeme

# AWS S3 — where uploaded trip photos are stored.
# Region and bucket have working defaults; credentials must be set.
AWS_REGION=us-east-2
S3_BUCKET=tripscale-photo-blog
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Amazon RDS (Aurora PostgreSQL) — trip metadata. IAM database auth: no
# password here; a short-lived token is minted from the AWS credentials above.
RDS_HOST=your-cluster.cluster-xxxx.us-east-2.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=postgres
RDS_USER=postgres
RDS_REGION=us-east-2
# Optional: path to the RDS CA bundle for full TLS verification.
# RDS_CA_PATH=./db/us-east-2-bundle.pem
